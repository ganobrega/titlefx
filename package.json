{
  "name": "titlefx",
  "version": "0.2.3",
  "description": "Lightweight library to format and apply document.title with presets and tab animations.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ganobrega/titlefx.git"
  },
  "bugs": {
    "url": "https://github.com/ganobrega/titlefx/issues"
  },
  "homepage": "https://github.com/ganobrega/titlefx#readme",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish --no-git-tag"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "typescript": "^6.0.2",
    "vitepress": "^1.6.4",
    "vue": "^3.5.13"
  }
}
